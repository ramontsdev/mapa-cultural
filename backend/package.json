{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for the Auth Example project",
  "main": "index.js",
  "keywords": [],
  "author": "Ramon Nunes",
  "license": "ISC",
  "packageManager": "pnpm@10.12.3",
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register --env-file .env ./src/main/server.ts",
    "build": "npm run prisma:generate && tsc && tsc-alias -p tsconfig.json && cp -r src/main/db dist/main/",
    "start": "node -r tsconfig-paths/register --env-file .env ./dist/main/server.js",
    "prisma:generate": "prisma generate --schema=./prisma/",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/",
    "prisma:studio": "prisma studio --schema=./prisma/",
    "lint": "eslint --config eslint.config.mjs \"src/**/*.{js,ts}\"",
    "hard-test": "tsx -r tsconfig-paths/register --env-file .env ./scripts/hard-test.ts",
    "seed": "tsx -r tsconfig-paths/register --env-file .env ./scripts/seed.ts",
    "etl-mapas-prod-to-local": "tsx --env-file .env scripts/etl-mapas-prod-to-local.ts",
    "import-backup-de-producao": "tsx -r tsconfig-paths/register --env-file .env scripts/import-backup-de-producao.ts",
    "audit-agent-files-in-backup": "tsx -r tsconfig-paths/register --env-file .env scripts/audit-agent-files-in-backup.ts",
    "delete-storage-by-path": "tsx -r tsconfig-paths/register --env-file .env scripts/delete-storage-by-path.ts",
    "migrate:mapas-prod-to-local-completo": "pnpm prisma migrate deploy --schema=./prisma && pnpm etl-mapas-prod-to-local && pnpm import-backup-de-producao",
    "typecheck": "tsc --noEmit",
    "lint:fix": "npm run lint -- --fix",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down -v"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/client-ses": "^3.882.0",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "bcryptjs": "^3.0.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.3.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.35.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.3.0",
    "pg": "^8.20.0",
    "prisma": "^7.1.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
