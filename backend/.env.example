# Server
PORT=4500
NODE_VERSION="22.17.1"

# Database
# Banco local Prisma (destino das migrações e do ETL)
DATABASE_URL="postgresql://root:root@localhost:5432/mapa_da_cultura_local"
#
# --- Migração Mapas (produção → local) ---
# 1) pnpm prisma migrate deploy   # ou: migrate dev
# 2) Defina SOURCE_DATABASE_URL = Postgres legado Mapas (somente leitura no ETL e na tabela file).
#    DATABASE_URL = destino (local), ex. mapa_da_cultura_local.
# 3) pnpm etl-mapas-prod-to-local  — copia usr, users, agent, event, … para DATABASE_URL
# 4) Backup de ficheiros em scripts/backup-de-producao/public-files (paths da tabela "file")
# 5) pnpm import-backup-de-producao — lê tabela "file" na origem, faz upload, cria media_asset no DATABASE_URL
#
# Ou tudo de uma vez (aplica migrações + ETL + mídias):
#    pnpm migrate:mapas-prod-to-local-completo
#
# SOURCE_DATABASE_URL="postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO"

# ETL: senha inicial comum dos utilizadores criados em `users` (bcrypt)
# ETL_DEFAULT_USER_PASSWORD="alteraraposmigracao"

# Authentication
JWT_SECRET="secret-example"
ALLOWED_ORIGINS="http://localhost:3000" # comma separated list of allowed origins

# AWS (SES e/ou S3 direto quando OBJECT_STORAGE_* não está configurado)
# AWS_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_BUCKET_NAME=""
# AWS_S3_PUBLIC_BASE_URL="https://..." # opcional; senão URL padrão s3.amazonaws.com

# Object Storage WS (ATI / OpenShift) — se OBJECT_STORAGE_BASE_URL e OBJECT_STORAGE_API_KEY
# estiverem definidos, uploads de mídia usam esta API em vez do S3 SDK.
OBJECT_STORAGE_BASE_URL="https://object-storage-ws-dev.apps.ocp.ati.pi.gov.br"
OBJECT_STORAGE_API_KEY=""
OBJECT_STORAGE_PROVIDER="MINIO" # ou AWS
OBJECT_STORAGE_RETENTION_DIAS="" # opcional
OBJECT_STORAGE_USUARIO_FALLBACK="mapas-migracao" # quando não há email (scripts)

# Import scripts: usuário informado na API ao enviar mídia (obrigatório em modo WS)
# IMPORT_MEDIA_STORAGE_USUARIO="mapas-migracao"

# APP CONFIGS
APP_NAME="Auth Example"
APP_DOMAIN="example.com.br"
APP_EMAIL="info@example.com.br"

# Email
EMAIL_FROM="Auth Example<info@example.com.br>"
